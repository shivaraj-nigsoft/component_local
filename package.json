    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.1.1",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-dts": "^4.5.4"
  },
  "dependencies": {
    "react-icons": "^5.5.0",
    "recharts": "^3.8.1"
